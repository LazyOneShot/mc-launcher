{
  "name": "mc-launcher",
  "version": "0.4.23",
  "description": "Custom Minecraft launcher with cloud modpacks",
  "author": "LazyOneShot",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "package": "electron-builder",
    "publish": "electron-builder --publish always",
    "publish:linux": "electron-builder --linux --publish always",
    "publish:win": "electron-builder --win --publish always",
    "publish:mac": "electron-builder --mac --publish always"
  },
  "dependencies": {
    "@azure/msal-node": "^2.6.0",
    "axios": "^1.6.0",
    "dotenv": "^16.4.5",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.8.9",
    "form-data": "^4.0.0",
    "fs-extra": "^11.2.0",
    "minecraft-launcher-core": "^3.18.2",
    "minecraft-server-util": "^5.4.4",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-router-dom": "^6.23.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.2.0",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.0",
    "electron-vite": "^2.2.0",
    "typescript": "^5.4.0"
  },
  "build": {
    "appId": "com.lazyoneshot.mc-launcher",
    "productName": "MC Launcher",
    "directories": {
      "output": "dist"
    },
    "extraResources": [
      {
        "from": "build/icon.png",
        "to": "icon.png"
      },
      {
        "from": "build/icon.ico",
        "to": "icon.ico"
      }
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "LazyOneShot",
        "repo": "mc-launcher",
        "releaseType": "release"
      }
    ],
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "build/icon.png",
      "artifactName": "MC-Launcher-${version}.${ext}",
      "category": "Game",
      "synopsis": "Cloud-synced Minecraft mod launcher",
      "description": "A custom Minecraft launcher with cloud-synced modpacks, Microsoft auth, and auto-updates."
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico",
      "artifactName": "MC-Launcher-Setup-${version}.${ext}"
    },
    "mac": {
      "target": "dmg",
      "icon": "build/icon.png",
      "artifactName": "MC-Launcher-${version}.${ext}",
      "category": "public.app-category.games"
    }
  }
}
